font-size = 32
font-style = medium
background = 000000
background-opacity = 0.97
background-blur-radius = 0

theme = "tokyonight_storm"

macos-titlebar-style = hidden
font-family = Hack Nerd Font

mouse-hide-while-typing = true

window-padding-y = 20,0
window-padding-x = 20
window-save-state = always

# custom-shader = shaders/cursor_warp.glsl
custom-shader = shaders/sonic_boom_cursor.glsl
custom-shader = shaders/cursor_blaze_tapered.glsl

custom-shader = shaders/blaze_sparks.glsl
# custom-shader = shaders/zoom_and_aberration.glsl

custom-shader = shaders/prefix_flash.glsl

# Keep animating even when unfocused (sahaj-b boom/ripple effects need this).
custom-shader-animation = always
