+/*
+ * Local patch: resolve a colour to RGB using the TERMINAL's real 16-colour
+ * palette for ANSI indices 0-15 (and bright 90-97), instead of tmux's built-in
+ * xterm defaults. Without this, dimming an ANSI colour starts from the wrong
+ * source (e.g. xterm green #00cd00 instead of the theme's #9ece6a), so the
+ * dimmed result doesn't match what the terminal shows when focused. Indices
+ * 16-255 are standard across terminals, so those fall through to colour_force_rgb.
+ *
+ * The palette below is Ghostty's tokyonight_storm. If you switch terminal theme,
+ * update these 16 values (from ~/.config/ghostty/themes/<theme> palette = N=...)
+ * and rebuild.
+ */
+static int
+colour_theme_rgb(int c)
+{
+	static const int p[16] = {
+		0x1d202f, 0xf7768e, 0x9ece6a, 0xe0af68,
+		0x7aa2f7, 0xbb9af7, 0x7dcfff, 0xa9b1d6,
+		0x414868, 0xff899d, 0x9fe044, 0xfaba4a,
+		0x8db0ff, 0xc7a9ff, 0xa4daff, 0xc0caf5
+	};
+
+	if (c & COLOUR_FLAG_RGB)
+		return (c);
+	if ((c & COLOUR_FLAG_256) && (c & 0xff) < 16)
+		return (p[c & 0xff] | COLOUR_FLAG_RGB);
+	if (c >= 0 && c <= 7)
+		return (p[c] | COLOUR_FLAG_RGB);
+	if (c >= 90 && c <= 97)
+		return (p[8 + c - 90] | COLOUR_FLAG_RGB);
+	return (colour_force_rgb(c));
+}
+
+/*
+ * Local patch: produce a dimmed version of a colour for inactive-pane content.
+ * Clean "same hue, just darker" dim: blend each channel `percent` toward the
+ * target colour (the pane/terminal background). No desaturation, so colours
+ * keep their hue and simply lose brightness — like reduced opacity over the
+ * background, which is what reads as a uniformly dimmed pane. `percent` comes
+ * from the `dim-inactive-percent` option (0 = no dim, 100 = fully background).
+ * If the source can't resolve to RGB the input is returned unchanged; if the
+ * target can't resolve, black is assumed.
+ */
+int
+colour_dim(int c, int target, int percent)
+{
+	u_char	r, g, b, tr, tg, tb;
+	int	rgb, trgb, sr, sg, sb, a;
+
+	a = percent;
+	if (a <= 0)
+		return (c);
+	if (a > 100)
+		a = 100;
+
+	rgb = colour_theme_rgb(c);
+	if (rgb == -1)
+		return (c);
+	trgb = colour_theme_rgb(target);
+	if (trgb == -1)
+		trgb = colour_join_rgb(0x00, 0x00, 0x00);
+
+	colour_split_rgb(rgb, &r, &g, &b);
+	colour_split_rgb(trgb, &tr, &tg, &tb);
+
+	/* Blend a% toward target — pure brightness reduction, hue preserved. */
+	sr = (r * (100 - a) + tr * a) / 100;
+	sg = (g * (100 - a) + tg * a) / 100;
+	sb = (b * (100 - a) + tb * a) / 100;
+
+	return (colour_join_rgb((u_char)sr, (u_char)sg, (u_char)sb));
+}
